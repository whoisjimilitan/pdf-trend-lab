generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Opportunity {
  id               String    @id @default(cuid())
  keyword          String
  pdfTitle         String    @default("")
  niche            String
  country          String    @default("US")
  searchVolume     Int
  opportunityScore Int
  competition      String
  trend            String
  easeToSell       String
  minPrice         Float
  maxPrice         Float
  emotionalIntent  String
  exactQuestions      String
  painPoint           String    @default("")
  hookPotential       String    @default("medium")
  hookAngle           String    @default("")
  pdfSuitability      String    @default("")
  actionabilityRating String    @default("medium")
  videoScript         String    @default("")
  pdfOutline          String    @default("[]")
  salesPage           String    @default("{}")
  volumeTier          String    @default("niche")
  gapScore            Int       @default(0)
  platformOfOrigin    String    @default("autocomplete")
  distributionStrategy String   @default("")
  saved               Boolean   @default(false)
  isQuickWin       Boolean   @default(false)
  isDiaspora       Boolean   @default(false)
  isExpat          Boolean   @default(false)
  isReturning      Boolean   @default(false)
  clusterId        String?
  cluster          Cluster?  @relation(fields: [clusterId], references: [id])
  products         Product[]
  hooks            Hook[]
  createdAt        DateTime  @default(now())
}

model Product {
  id             String      @id @default(cuid())
  opportunityId  String
  opportunity    Opportunity @relation(fields: [opportunityId], references: [id])
  title          String
  slug           String      @default("")
  pdfContent     String
  salesPageCopy  String
  seoPageContent String
  status         String      @default("draft")
  published      Boolean     @default(false)
  salesCount     Int         @default(0)
  revenue        Float       @default(0)
  shopifyId      String?
  gumroadUrl     String      @default("")
  createdAt      DateTime    @default(now())
}

model Hook {
  id            String       @id @default(cuid())
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  text          String
  platform      String
  emotionType   String
  niche         String
  usageCount    Int          @default(0)
  createdAt     DateTime     @default(now())
}

model Cluster {
  id            String        @id @default(cuid())
  name          String
  theme         String
  emotionalCore String
  opportunities Opportunity[]
  createdAt     DateTime      @default(now())
}

model EmailSubscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  productSlug String?
  country     String?
  source      String?
  createdAt   DateTime @default(now())
}

model PlantingLog {
  id        String   @id @default(cuid())
  productId String
  platform  String
  hookId    String?
  postedAt  DateTime @default(now())
  notes     String?
}

model SearchQuery {
  id        String   @id @default(cuid())
  query     String
  country   String?
  source    String   @default("homepage")
  createdAt DateTime @default(now())
}

model Partner {
  id                String        @id @default(cuid())
  email             String        @unique
  code              String        @unique
  name              String?
  referredBy        String?
  totalEarned       Float         @default(0)
  salesCount        Int           @default(0)
  communityCountry  String?
  platform          String?
  communityTopics   String        @default("[]")
  onboarded         Boolean       @default(false)
  curatedGuides     String        @default("[]")
  createdAt         DateTime      @default(now())
  sales             PartnerSale[]
}

model PartnerSale {
  id          String   @id @default(cuid())
  partnerId   String
  partner     Partner  @relation(fields: [partnerId], references: [id])
  productSlug String
  saleAmount  Float
  commission  Float
  createdAt   DateTime @default(now())
}

model DailyLoop {
  id        String   @id @default(cuid())
  date      String
  status    String   @default("pending")
  niche     String
  keyword   String
  pdfDone   Boolean  @default(false)
  hooksDone Boolean  @default(false)
  published Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
}

// Phase A: Instrumentation
// Shadow logging for Evidence Validation Engine
// Zero behavior change. Current system runs unchanged.
// Logs accumulate for statistical analysis.
model ValidationLog {
  id                    String    @id @default(cuid())
  validationId          String    @unique // Links to InsightObject.validationId
  prospectId            String

  // Decision reasoning (learning)
  selectedInsightType   String
  selectedBecause       String    @db.Text
  rejectedInsightsJson  String    @db.Text // JSON: rejected insights and why

  // Validation details
  confidenceScore       Float     // 0.0–1.0 continuous
  confidenceBand        String    // Presentation: PROVEN, HIGH_CONFIDENCE, etc.
  status                String    // APPROVED, PENDING_MORE_EVIDENCE, REJECTED_FOR_NOW

  // Evidence provenance
  evidenceSourcesJson   String    @db.Text // JSON: array of evidence sources
  evidenceSourceCount   Int

  // Contradictions
  contradictionsJson    String    @db.Text // JSON: contradiction details
  contradictionsCount   Int       @default(0)

  // Outcomes (populated later)
  emailSent             Boolean   @default(false)
  emailSentAt           DateTime?
  emailOpenRate         Float?
  pageVisited           Boolean   @default(false)
  pageVisitedAt         DateTime?
  pageDwellTime         Int?      // Seconds
  pageScrollDepth       Float?    // 0.0-1.0
  ctaClicked            Boolean   @default(false)
  ctaClickedAt          DateTime?
  replyReceived         Boolean   @default(false)
  replyReceivedAt       DateTime?
  conversionStatus      String?   // converted, not_converted, pending

  // KPI tracking (learning signals)
  kpiInsightAccuracy    Boolean?  // Did prospect confirm this insight?
  kpiEngagementDepth    String?   // none, open, click, page_visit, cta_click, reply
  kpiConversationStarts Int       @default(0)
  kpiConversion         Boolean   @default(false)

  // Metadata
  leadCategory          String
  leadLocations         Int
  enrichmentLevel       String    // full, partial, minimal

  // Timing
  validatedAt           DateTime  @default(now())
  outcomeEvaluatedAt    DateTime?
  updatedAt             DateTime  @updatedAt

  @@index([prospectId])
  @@index([status])
  @@index([selectedInsightType])
  @@index([kpiInsightAccuracy])
  @@index([conversionStatus])
}

model PageEngagementLog {
  id                  String    @id @default(cuid())
  prospectId          String
  insightId           String
  validationId        String
  pageViewed          Boolean   @default(false)
  viewedAt            DateTime?
  dwellTimeSeconds    Int?
  scrollDepthPercent  Float?
  ctaClicks           Int       @default(0)
  ctaClickedAt        DateTime?
  returnVisits        Int       @default(0)
  lastVisitAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([prospectId, insightId])
  @@index([prospectId])
  @@index([insightId])
  @@index([validationId])
  @@index([createdAt])
}

// Phase 2: Approval Workflow
// Type-safe enum for approval status transitions
enum ApprovalStatus {
  NEW
  ACTIVE
  PROMOTED
  ARCHIVED
}

// Approval metadata for validated insights (metadata-only, no duplication)
model ApprovedInsight {
  id                String          @id @default(cuid())

  // Single reference to ValidationLog (canonical insight source)
  validationId      String          @unique
  validationLog     ValidationLog   @relation(
    fields: [validationId],
    references: [validationId],
    onDelete: Restrict
  )

  // Approval metadata only (do NOT duplicate insight data)
  approvalStatus    ApprovalStatus  @default(NEW)
  approvedAt        DateTime        @default(now())

  // Audit trail
  promotionHistory  ApprovalPromotion[]

  // Timestamps
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([approvalStatus])
  @@index([approvedAt])
  @@index([approvalStatus, approvedAt])
  @@unique([validationId])
}

// Immutable audit trail of all state transitions
model ApprovalPromotion {
  id                String          @id @default(cuid())

  // Reference to approved insight (with delete protection)
  approvedInsightId String
  approvedInsight   ApprovedInsight @relation(
    fields: [approvedInsightId],
    references: [id],
    onDelete: Restrict
  )

  // State transition record
  fromStatus        ApprovalStatus
  toStatus          ApprovalStatus
  promotionReason   String          @db.Text

  // Decision metadata
  decidedAt         DateTime        @default(now())
  decidedBy         String?

  @@index([approvedInsightId])
  @@index([decidedAt])
  @@index([toStatus])
  @@index([approvedInsightId, decidedAt])
}
