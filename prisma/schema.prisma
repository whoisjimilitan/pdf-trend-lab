  postcode_from           String?
  postcode_to             String?
  distance_miles          Int?
  large_items             Json?
  timeframe               String?
  help_loading            String?
  duration                String?
  driver_id               String?
  status                  String?                   @default("new")
  job_date                DateTime?                 @db.Date
  price                   Decimal?
  notes                   String?
