generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Assumption {
  id        String            @id
  statement String            @unique
  status    AssumptionStatus?
}

model Business {
  id              String            @id
  name            String
  placeId         String?           @unique
  createdAt       DateTime          @default(now())
  address         String?
  discoveredAt    DateTime?
  location        String?
  niche           String?
  phone           String?
  pipelineState   PipelineState     @default(DISCOVERED)
  sourcePayload   Json?
  sourceType      String?
  website         String?
  Conversation    Conversation[]
  EvidencePattern EvidencePattern[]
  Hypothesis      Hypothesis[]
  Review          Review[]
}

model Conversation {
  id         String   @id
  businessId String
  question   String
  createdAt  DateTime @default(now())
  status     String   @default("pending")
  Business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  Outcome    Outcome?
}

model EvidencePattern {
  id          String       @id
  businessId  String
  patternType String
  occurrences Int
  examples    Json
  createdAt   DateTime     @default(now())
  Business    Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  Hypothesis  Hypothesis[]
}

model Hypothesis {
  id                String            @id
  businessId        String
  statement         String
  status            HypothesisStatus?
  evidenceCount     Int               @default(0)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime
  evidencePatternId String?
  Business          Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  EvidencePattern   EvidencePattern?  @relation(fields: [evidencePatternId], references: [id])
}

model ObservationEvent {
  id         String            @id
  sourceType ObservationSource
  sourceId   String
  text       String
  createdAt  DateTime          @default(now())
}

model Outcome {
  id                   String               @id
  conversationId       String               @unique
  signalType           OutcomeSignal
  signalClassification SignalClassification
  unexpectedLearning   String?
  createdAt            DateTime             @default(now())
  Conversation         Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Review {
  id         String   @id
  businessId String
  text       String
  rating     Int?
  author     String?
  createdAt  DateTime @default(now())
  Business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Opportunity {
  id                  String    @id @default(cuid())
  keyword             String
  niche               String
  country             String    @default("US")
  searchVolume        Int
  opportunityScore    Int
  competition         String
  trend               String
  easeToSell          String
  minPrice            Float
  maxPrice            Float
  emotionalIntent     String
  exactQuestions      String    @default("")
  painPoint           String    @default("")
  hookPotential       String    @default("medium")
  hookAngle           String    @default("")
  pdfSuitability      String    @default("")
  actionabilityRating String    @default("medium")
  videoScript         String    @default("")
  pdfOutline          String    @default("[]")
  salesPage           String    @default("{}")
  volumeTier          String    @default("niche")
  gapScore            Int       @default(0)
  platformOfOrigin    String    @default("autocomplete")
  distributionStrategy String   @default("")
  saved               Boolean   @default(false)
  isQuickWin          Boolean   @default(false)
  isDiaspora          Boolean   @default(false)
  isExpat             Boolean   @default(false)
  isReturning         Boolean   @default(false)
  clusterId           String?
  pdfTitle            String    @default("")
  products            Product[]
  hooks               Hook[]
  createdAt           DateTime  @default(now())
}

model Product {
  id             String    @id @default(cuid())
  opportunityId  String
  opportunity    Opportunity @relation(fields: [opportunityId], references: [id])
  title          String
  slug           String    @default("")
  pdfContent     String
  salesPageCopy  String
  seoPageContent String
  status         String    @default("draft")
  published      Boolean   @default(false)
  salesCount     Int       @default(0)
  revenue        Float     @default(0)
  shopifyId      String?
  gumroadUrl     String    @default("")
  createdAt      DateTime  @default(now())
}

model Hook {
  id            String       @id @default(cuid())
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])
  text          String
  platform      String
  emotionType   String
  niche         String
  usageCount    Int          @default(0)
  createdAt     DateTime     @default(now())
}

model b2b_email_events {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outreach_id           String?                 @db.Uuid
  lead_id               String?                 @db.Uuid
  event_type            String
  timestamp             DateTime                @db.Timestamptz(6)
  metadata              Json?
  created_at            DateTime?               @default(now()) @db.Timestamptz(6)
  b2b_leads             b2b_leads?              @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  b2b_outreach          b2b_outreach?           @relation(fields: [outreach_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  b2b_email_link_clicks b2b_email_link_clicks[]

  @@index([lead_id], map: "idx_b2b_email_events_lead")
  @@index([outreach_id], map: "idx_b2b_email_events_outreach")
  @@index([timestamp(sort: Desc)], map: "idx_b2b_email_events_timestamp")
  @@index([event_type], map: "idx_b2b_email_events_type")
}

model b2b_email_link_clicks {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id         String?           @db.Uuid
  lead_id          String?           @db.Uuid
  link_url         String?
  link_text        String?
  clicked_at       DateTime          @db.Timestamptz(6)
  created_at       DateTime?         @default(now()) @db.Timestamptz(6)
  b2b_email_events b2b_email_events? @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  b2b_leads        b2b_leads?        @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([lead_id], map: "idx_b2b_email_link_clicks_lead")
}

model b2b_heat_score_history {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id             String?    @db.Uuid
  heat_score          Int
  engagement_score    Int?
  qualification_score Int?
  intent_score        Int?
  recorded_at         DateTime?  @default(now()) @db.Timestamptz(6)
  created_at          DateTime?  @default(now()) @db.Timestamptz(6)
  b2b_leads           b2b_leads? @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([lead_id], map: "idx_b2b_heat_score_history_lead")
  @@index([recorded_at(sort: Desc)], map: "idx_b2b_heat_score_history_recorded")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model b2b_leads {
  id                         String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_name              String
  business_category          String?
  contact_name               String?
  email                      String?
  phone                      String?
  website                    String?
  city                       String?
  postcode                   String?
  google_place_id            String?
  pain_point                 String?
  pain_point_review          String?
  review_rating              Decimal?                  @db.Decimal(2, 1)
  source                     String?                   @default("discovery")
  status                     String?                   @default("new")
  notes                      String?
  niche                      String?
  landing_page_url           String?
  business_evidence          Json?
  human_observations         Json?
  business_timeline          Json?
  created_at                 DateTime                  @default(now())
  updated_at                 DateTime
  lead_state                 String?                   @default("new")
  transitioned_at            DateTime?                 @db.Timestamptz(6)
  driver_id                  String?
  latitude                   Decimal?                  @db.Decimal(10, 8)
  longitude                  Decimal?                  @db.Decimal(11, 8)
  email_sent_at              DateTime?                 @db.Timestamptz(6)
  qualified_business_id      String?                   @unique(map: "uq_b2b_leads_qualified_business") @db.Uuid
  discovered_business_id     String?                   @db.Uuid
  promoted_from_qualified_at DateTime?                 @db.Timestamptz(6)
  outreach_eligible          Boolean?                  @default(false)
  engagement_score           Int?                      @default(0)
  last_engagement_at         DateTime?                 @db.Timestamptz(6)
  lead_tier                  String?
  engaged_today              Boolean?                  @default(false)
  last_engagement_type       String?
  pipeline_stage             String?                   @default("NEW")
  b2b_email_events           b2b_email_events[]
  b2b_email_link_clicks      b2b_email_link_clicks[]
  b2b_heat_score_history     b2b_heat_score_history[]
  discovered_businesses      discovered_businesses?    @relation(fields: [discovered_business_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  drivers                    drivers?                  @relation(fields: [driver_id], references: [id], onUpdate: NoAction)
  qualified_businesses       qualified_businesses?     @relation(fields: [qualified_business_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  b2b_learning_outcomes      b2b_learning_outcomes[]
  b2b_outreach               b2b_outreach[]
  b2b_prospect_brief_cache   b2b_prospect_brief_cache?
  b2b_prospect_qualifications b2b_prospect_qualifications? @relation("b2b_prospect_qualifications")
  b2b_standing_orders        b2b_standing_orders[]
  lead_promotions            lead_promotions[]
  lead_state_transitions     lead_state_transitions[]

  @@index([created_at])
  @@index([status])
  @@index([created_at(sort: Desc)], map: "idx_b2b_leads_created")
  @@index([driver_id], map: "idx_b2b_leads_driver")
  @@index([engaged_today], map: "idx_b2b_leads_engaged_today")
  @@index([engagement_score(sort: Desc), last_engagement_at(sort: Desc)], map: "idx_b2b_leads_engagement")
  @@index([lead_state], map: "idx_b2b_leads_lead_state")
  @@index([pipeline_stage], map: "idx_b2b_leads_pipeline_stage")
  @@index([qualified_business_id], map: "idx_b2b_leads_qualified_business")
  @@index([status], map: "idx_b2b_leads_status")
  @@index([lead_tier], map: "idx_b2b_leads_tier")
}

model b2b_learning_outcomes {
  id                           String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  qualified_business_id        String?               @db.Uuid
  lead_id                      String?               @db.Uuid
  outcome_type                 String
  outcome_value                Int?                  @default(1)
  business_category            String?
  opportunity_score_at_outcome Decimal?              @db.Decimal(5, 2)
  days_to_outcome              Int?
  engagement_signals           Json?
  created_at                   DateTime?             @default(now()) @db.Timestamptz(6)
  b2b_leads                    b2b_leads?            @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  qualified_businesses         qualified_businesses? @relation(fields: [qualified_business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model b2b_orchestration_logs {
  id                        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  run_id                    String
  started_at                DateTime  @db.Timestamptz(6)
  completed_at              DateTime  @db.Timestamptz(6)
  discovery_count           Int?
  businesses_found          Int?
  leads_created             Int?
  drivers_matched           Int?
  emails_sent               Int?
  standing_orders_processed Int?
  jobs_created              Int?
  failures                  String[]
  status                    String
  execution_details         Json?
  created_at                DateTime? @default(now()) @db.Timestamptz(6)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model b2b_orchestration_runs {
  id                        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  run_id                    String    @unique
  started_at                DateTime  @db.Timestamptz(6)
  completed_at              DateTime  @db.Timestamptz(6)
  discovery_count           Int?      @default(0)
  businesses_found          Int?      @default(0)
  leads_created             Int?      @default(0)
  drivers_matched           Int?      @default(0)
  emails_sent               Int?      @default(0)
  standing_orders_processed Int?      @default(0)
  jobs_created              Int?      @default(0)
  failures                  String[]  @default([])
  status                    String
  duration_ms               Int?
  execution_details         Json?
  created_at                DateTime? @default(now()) @db.Timestamptz(6)

  @@index([run_id], map: "idx_runs_run_id")
  @@index([started_at(sort: Desc)], map: "idx_runs_started_at")
  @@index([status], map: "idx_runs_status")
}

model b2b_outreach {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id           String             @db.Uuid
  subject           String?
  body              String?
  sent_at           DateTime?
  follow_up_1_at    DateTime?
  follow_up_2_at    DateTime?
  replied           Boolean?           @default(false)
  replied_at        DateTime?
  email_type        String?            @default("initial")
  resend_message_id String?
  pressure_type     String?
  copy_variant      String?
  sent_by           String?            @default("autonomous")
  created_at        DateTime           @default(now())
  b2b_email_events  b2b_email_events[]
  b2b_responses     b2b_responses[]
  b2b_leads         b2b_leads          @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  @@index([lead_id])
  @@index([lead_id], map: "idx_b2b_outreach_lead")
  @@index([pressure_type])
  @@index([copy_variant])
  @@index([sent_by])
}

model b2b_responses {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  outreach_id   String       @db.Uuid
  response_type String
  responded_at  DateTime     @default(now())
  response_time_minutes Int?
  created_at    DateTime     @default(now())
  b2b_outreach  b2b_outreach @relation(fields: [outreach_id], references: [id], onDelete: Cascade)

  @@index([outreach_id])
  @@index([response_type])
  @@index([responded_at(sort: Desc)])
}

model b2b_prospect_qualifications {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id            String   @db.Uuid
  prospect_first_name String?
  prospect_role      String?
  prospect_phone     String?
  prospect_email     String?
  proposed_call_time String?
  notes              String?
  created_at         DateTime @default(now())
  updated_at         DateTime @default(now())
  b2b_leads          b2b_leads @relation("b2b_prospect_qualifications", fields: [lead_id], references: [id], onDelete: Cascade)

  @@index([lead_id])
  @@unique([lead_id])
}

model b2b_import_logs {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  file_name         String
  total_rows        Int
  rows_processed    Int?     @default(0)
  rows_duplicates   Int?     @default(0)
  rows_sent         Int?     @default(0)
  rows_errors       Int?     @default(0)
  error_details     Json?
  imported_at       DateTime @default(now())
  created_at        DateTime @default(now())

  @@index([imported_at(sort: Desc)])
}

model b2b_learning_metrics {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pressure_type   String
  industry        String?
  copy_variant    String?
  emails_sent     Int      @default(0)
  responses_yes   Int      @default(0)
  responses_no    Int      @default(0)
  yes_rate        Decimal? @db.Decimal(5, 2)
  conversion_rate Decimal? @db.Decimal(5, 2)
  updated_at      DateTime @default(now())
  created_at      DateTime @default(now())

  @@unique([pressure_type, industry, copy_variant])
  @@index([pressure_type])
  @@index([industry])
  @@index([yes_rate(sort: Desc)])
  @@index([updated_at(sort: Desc)])
}

model b2b_prospect_brief_cache {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id    String?    @unique @db.Uuid
  brief_data Json
  created_at DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at DateTime?  @default(now()) @db.Timestamptz(6)
  b2b_leads  b2b_leads? @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model b2b_standing_orders {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id           String    @db.Uuid
  business_name     String
  contact_name      String?
  contact_phone     String?
  contact_email     String?
  pickup_address    String?
  pickup_postcode   String?
  delivery_address  String?
  delivery_postcode String?
  service_type      String?
  frequency         String?   @default("weekly")
  day_of_week       Int?
  preferred_time    String?
  price             Decimal?  @db.Decimal(10, 2)
  notes             String?
  active            Boolean?  @default(true)
  last_generated_at DateTime?
  next_scheduled_at DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @default(now())
  b2b_leads         b2b_leads @relation(fields: [lead_id], references: [id])
}

model discovered_businesses {
  id                                                                                    String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  google_place_id                                                                       String?               @unique
  business_name                                                                         String
  address                                                                               String?
  postcode                                                                              String?
  category                                                                              String?
  source                                                                                String?               @default("discovery")
  discovered_at                                                                         DateTime?             @default(now()) @db.Timestamptz(6)
  raw_data                                                                              Json?
  b2b_leads                                                                             b2b_leads[]
  enriched_businesses_enriched_businesses_discovered_business_idTodiscovered_businesses enriched_businesses[] @relation("enriched_businesses_discovered_business_idTodiscovered_businesses")
  enriched_businesses_enriched_businesses_google_place_idTodiscovered_businesses        enriched_businesses[] @relation("enriched_businesses_google_place_idTodiscovered_businesses")
  opportunity_signals                                                                   opportunity_signals[]
  qualified_businesses                                                                  qualified_businesses?

  @@index([discovered_at(sort: Desc)], map: "idx_discovered_businesses_created")
  @@index([google_place_id], map: "idx_discovered_businesses_place_id")
  @@index([postcode], map: "idx_discovered_businesses_postcode")
}

model discovery_config {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mode       String
  niche      String
  locations  String[]
  enabled    Boolean?  @default(true)
  priority   Int?      @default(50)
  min_score  Decimal?  @default(40) @db.Decimal(5, 2)
  created_by String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)

  @@index([niche], map: "idx_discovery_config_niche")
}

model discovery_sources {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source_type String
  source_name String?
  description String?
  enabled     Boolean?  @default(true)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
}

model driver_availability {
  id             String   @id
  driver_id      String
  available_date DateTime @db.Date
  notes          String?
  created_at     DateTime @default(now())
  drivers        drivers  @relation(fields: [driver_id], references: [id], onDelete: Cascade)

  @@unique([driver_id, available_date])
}

model driver_location_history {
  id              String   @id
  job_id          String?
  driver_clerk_id String?
  lat             Decimal?
  lng             Decimal?
  accuracy        Decimal?
  eta_minutes     Int?
  recorded_at     DateTime @default(now())
  jobs            jobs?    @relation(fields: [job_id], references: [id])

  @@index([job_id])
  @@index([recorded_at])
  @@index([job_id], map: "idx_dlh_job_id")
  @@index([recorded_at], map: "idx_dlh_recorded_at")
}

model drivers {
  id                     String                @id
  clerk_user_id          String?               @unique
  full_name              String?
  email                  String?               @unique
  phone                  String?
  vehicle_type           String?
  area                   String?
  days_preference        String?
  stripe_customer_id     String?
  stripe_subscription_id String?
  subscription_status    String?               @default("inactive")
  rating_avg             Decimal?
  rating_count           Int?                  @default(0)
  profile_live           Boolean?              @default(false)
  last_seen_at           DateTime?
  created_at             DateTime              @default(now())
  updated_at             DateTime              @default(now())
  postcode               String?               @db.VarChar(20)
  latitude               Decimal?              @db.Decimal(10, 8)
  longitude              Decimal?              @db.Decimal(11, 8)
  radius_miles           Int?                  @default(10)
  available_days         String[]
  b2b_opt_in             Boolean?              @default(false)
  b2b_leads              b2b_leads[]
  driver_availability    driver_availability[]
  earnings               earnings[]
  job_invoices           job_invoices[]
  jobs                   jobs[]
  ratings                ratings[]

  @@index([last_seen_at])
  @@index([profile_live])
  @@index([postcode], map: "idx_drivers_postcode")
}

model earnings {
  id         String    @id
  driver_id  String?
  job_id     String?
  amount     Decimal?
  status     String?   @default("pending")
  paid_at    DateTime?
  notes      String?
  created_at DateTime  @default(now())
  drivers    drivers?  @relation(fields: [driver_id], references: [id])
  jobs       jobs?     @relation(fields: [job_id], references: [id])
}

model enriched_businesses {
  id                                                                                      String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  discovered_business_id                                                                  String?                @db.Uuid
  google_place_id                                                                         String?
  website                                                                                 String?
  phone                                                                                   String?
  email                                                                                   String?
  review_count                                                                            Int?
  average_rating                                                                          Decimal?               @db.Decimal(3, 2)
  review_summary                                                                          Json?
  digital_signals                                                                         Json?
  transport_signals                                                                       Json?
  ai_observations                                                                         String?
  enriched_at                                                                             DateTime?              @default(now()) @db.Timestamptz(6)
  updated_at                                                                              DateTime?              @default(now()) @db.Timestamptz(6)
  discovered_businesses_enriched_businesses_discovered_business_idTodiscovered_businesses discovered_businesses? @relation("enriched_businesses_discovered_business_idTodiscovered_businesses", fields: [discovered_business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  discovered_businesses_enriched_businesses_google_place_idTodiscovered_businesses        discovered_businesses? @relation("enriched_businesses_google_place_idTodiscovered_businesses", fields: [google_place_id], references: [google_place_id], onDelete: NoAction, onUpdate: NoAction)
  qualified_businesses                                                                    qualified_businesses[]

  @@index([discovered_business_id], map: "idx_enriched_businesses_discovered")
  @@index([google_place_id], map: "idx_enriched_businesses_google_place")
}

model job_events {
  id         String       @id
  job_id     String
  event_type JobEventType
  latitude   Decimal?
  longitude  Decimal?
  timestamp  DateTime     @default(now())
  created_at DateTime     @default(now())
  jobs       jobs         @relation(fields: [job_id], references: [id], onDelete: Cascade)
  job_photos job_photos[]

  @@index([job_id])
  @@index([timestamp])
}

model job_invoices {
  id             String           @id
  job_id         String
  driver_id      String
  invoice_number String           @unique
  amount         Decimal
  status         JobInvoiceStatus @default(pending)
  issued_at      DateTime         @default(now())
  paid_at        DateTime?
  created_at     DateTime         @default(now())
  drivers        drivers          @relation(fields: [driver_id], references: [id], onDelete: Cascade)
  jobs           jobs             @relation(fields: [job_id], references: [id], onDelete: Cascade)

  @@index([driver_id])
  @@index([job_id])
  @@index([status])
}

